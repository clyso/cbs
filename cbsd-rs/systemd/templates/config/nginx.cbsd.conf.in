server {
  server_name {{domain}};
  
  ## Enable the 'listen' directive for IPv4 and IPv6 according
  ## to your deployment.
  # listen 127.0.0.1:443 ssl;
  # listen [::1]:443 ssl;
  http2 on;

  server_tokens off;

  location /api {
    proxy_pass https://localhost:8080;
    proxy_http_version 1.1;
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection "upgrade";
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header Host $host;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
  }

  location / {
    proxy_pass https://localhost:3000;
    proxy_http_version 1.1;
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection "upgrade";
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header Host $host;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
  }

  ## Enable SSL configuration for secure connections.
  # ssl_certificate /etc/nginx/vhosts.d/_certs/{{domain}}.cert;
  # ssl_certificate_key /etc/nginx/vhosts.d/_certs/{{domain}}.key;
}

