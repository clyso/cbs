# CBS build service daemon (cbsd-rs) — logrotate configuration
# Copyright (C) 2026  Clyso
#
# Generated by install.sh for deployment '{{deployment}}'.
# Rotates application logs for all services (server + workers).
#
# The application writes to a single stable file (Rotation::NEVER).
# This config handles daily rotation, compression, and retention.

{{cbsd_rs_data}}/{{deployment}}/*/logs/*.log {
    daily
    rotate 30
    compress
    delaycompress
    missingok
    notifempty
    copytruncate
}
