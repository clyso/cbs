#
# Runs logrotate daily for the '%i' deployment. Persistent=true ensures
# missed runs (e.g. host was off at midnight) are caught up on boot.

[Unit]
Description=Rotate cbsd logs for '%i' deployment

[Timer]
OnCalendar=*-*-* 00:00:00
Persistent=true
RandomizedDelaySec=300

[Install]
WantedBy=timers.target
