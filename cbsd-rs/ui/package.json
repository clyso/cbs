{
  "name": "cbs",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "lint:types": "vue-tsc --build --force",
    "lint:eslint": "eslint --no-fix --max-warnings 0",
    "lint:oxlint": "oxlint . -D correctness",
    "lint:stylelint": "stylelint \"src/**/*.{vue,css,scss}\"",
    "lint:prettier": "prettier --check \"src/\"",
    "fix:eslint": "eslint . --fix",
    "fix:oxlint": "oxlint . --fix -D correctness",
    "fix:stylelint": "stylelint \"src/**/*.{vue,css,scss}\" --fix",
    "fix:prettier": "prettier --write src/",
    "lint": "run-s lint:*",
    "fix": "run-s fix:*",
    "stylelint-scss-check": "stylelint-config-prettier-scss-check",
    "prepare": "husky",
    "test:unit": "vitest"
  },
  "dependencies": {
    "@clyso/clyso-ui-kit": "^1.0.1",
    "axios": "^1.13.4",
    "date-fns": "^4.1.0",
    "fast-glob": "^3.3.3",
    "js-cookie": "^3.0.5",
    "lodash-es": "^4.17.23",
    "naive-ui": "^2.43.2",
    "pinia": "^3.0.4",
    "vue": "^3.5.25",
    "vue-i18n": "^11.2.8",
    "vue-router": "^4.6.3"
  },
  "devDependencies": {
    "@tsconfig/node20": "^20.1.8",
    "@types/js-cookie": "^3.0.6",
    "@types/node": "^24.10.1",
    "@vitejs/plugin-vue": "^6.0.2",
    "@vitest/coverage-v8": "3",
    "@vitest/eslint-plugin": "^1.6.7",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.6.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.8.1",
    "eslint": "^9.39.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-oxlint": "^1.46.0",
    "eslint-plugin-vue": "^10.7.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.0",
    "npm-run-all": "^4.1.5",
    "oxlint": "^1.47.0",
    "postcss-html": "^1.8.1",
    "prettier": "^3.8.1",
    "sass-embedded": "^1.93.3",
    "stylelint": "^17.2.0",
    "stylelint-config-prettier-scss": "^1.0.0",
    "stylelint-config-recommended-scss": "^17.0.0",
    "stylelint-config-recommended-vue": "^1.6.1",
    "stylelint-prettier": "^5.0.3",
    "stylelint-scss": "^7.0.0",
    "typescript": "^5.9.3",
    "vite": "^7.2.6",
    "vite-plugin-svg-icons": "^2.0.1",
    "vite-plugin-vue-devtools": "^8.0.5",
    "vitest": "3",
    "vue-tsc": "^3.1.5"
  }
}
