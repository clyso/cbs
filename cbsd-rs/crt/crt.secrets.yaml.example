# crt.secrets.yaml — copy to `crt.secrets.yaml` (git-ignored; chmod 600).
# Secrets only (design §9). Non-secret config lives in crt.config.yaml.

# Required when the store backend is `s3`:
s3:
  access_key_id: AKIAEXAMPLE
  secret_access_key: example-secret-key

# Required for `crt release seal` and `crt release materialize` — the OpenPGP
# signing key lives in Vault and is fetched at sign time (design §6.1).
#
# Authenticate with EXACTLY ONE of `token`, `userpass`, or `approle`:
# vault:
#   addr: https://vault.example.com
#   # 1. a pre-issued token:
#   token: s.exampletoken
#   # 2. or username/password (mount defaults to `userpass`):
#   userpass:
#     username: my-user
#     password: my-password
#     # mount: userpass
#   # 3. or AppRole (mount defaults to `approle`):
#   approle:
#     role_id: my-role-id
#     secret_id: my-secret-id
#     # mount: approle
#   # Named signing-key secrets. crt.config.yaml's `gpg_private_key` picks one.
#   # `path` is the KV v2 path (its first segment is the mount); the *_field keys
#   # name the fields inside that secret (defaults: private-key / passphrase),
#   # so a secret shaped { "key": "...", "passphrase": "..." } sets key field
#   # `key`. Matches cbscore's GPGVaultPrivateKeySecret convention.
#   keys:
#     release-signing:
#       path: ces-kv/gpg/pvt
#       private_key_field: key
#       passphrase_field: passphrase
