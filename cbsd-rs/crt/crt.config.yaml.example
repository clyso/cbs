# crt.config.yaml — copy to `crt.config.yaml` (git-ignored) and edit.
# Non-secret configuration (design §9). Credentials live in crt.secrets.yaml.

component: ceph

# Store backend — exactly one of `local` or `s3`.
store:
  local: /var/lib/crt/store
  # s3:
  #   endpoint: https://s3.example.com
  #   region: us-east-1
  #   bucket: my-crt-bucket
  #   prefix: crt/

# Allowed risk-component labels for `release add --component` (design §9).
# An empty list (or omitting this key) accepts any component.
risk_components: [rgw, rgw-multisite, dashboard, build, docs, other]

# Published location of Clyso's OpenPGP public key, used by `release verify`
# (design §6.1). An http(s) URL or a local path; the `--public-key` flag
# overrides it.
public_key_url: https://download.clyso.com/crt/crt-pubkey.asc

# Which `vault.keys` entry (defined in crt.secrets.yaml) to sign with, used by
# `release seal` / `release materialize`. Defaults to `gpg_signing_private`.
gpg_private_key: release-signing

# Namespaces → channels. A release name resolves to a channel by prefix
# (e.g. `ces-v18.2.0` → channel `ces`); the most specific channel wins.
# `branding` is snapshotted into the manifest at seal time and shown by
# `release info`.
namespaces:
  clyso-enterprise:
    channels:
      ces:
        branding:
          display_name: Clyso Enterprise Storage
          blurb: Long-term-supported, hardened Ceph for enterprises.
          footer: © Clyso — https://clyso.com

# Config and secrets paths default to ./crt.config.yaml and ./crt.secrets.yaml;
# override with --config / --secrets or $CRT_CONFIG / $CRT_SECRETS.
